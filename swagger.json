{
  "openapi": "3.0.0",
  "info": {
    "title": "Jitterbit API - Order Management",
    "version": "1.0.0",
    "description": "API desenvolvida para o teste teórico da Jitterbit. Gerencia pedidos com mapeamento de dados e autenticação JWT."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Insira o token JWT gerado na rota /login"
      }
    }
  },
  "paths": {
    "/login": {
      "post": {
        "summary": "Gera um token JWT para autenticação",
        "description": "Endpoint mockado para gerar credencial de acesso às rotas protegidas.",
        "responses": {
          "200": { "description": "Token gerado com sucesso" }
        }
      }
    },
    "/order": {
      "post": {
        "summary": "Cria um novo pedido",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "numeroPedido": "v10089015vdb-01",
                "valor Total": 10000,
                "dataCriacao": "2023-07-19T12:24:11.5299601+00:00",
                "items": [
                  {
                    "idItem": "2434",
                    "quantidadeltem": 1,
                    "valorltem": 1000
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Pedido criado com sucesso" },
          "401": { "description": "Acesso negado. Token não fornecido ou inválido." }
        }
      }
    },
    "/order/list": {
      "get": {
        "summary": "Lista todos os pedidos",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de pedidos retornada com sucesso" },
          "401": { "description": "Acesso negado." }
        }
      }
    },
    "/order/{id}": {
      "get": {
        "summary": "Busca um pedido pelo ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "O orderId do pedido"
          }
        ],
        "responses": {
          "200": { "description": "Pedido encontrado" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um pedido existente",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "value": 15000 }
            }
          }
        },
        "responses": {
          "200": { "description": "Pedido atualizado" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "delete": {
        "summary": "Deleta um pedido pelo ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Pedido deletado com sucesso" },
          "404": { "description": "Pedido não encontrado" }
        }
      }
    }
  }
}
