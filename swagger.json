{
  "openapi": "3.0.0",
  "info": {
    "title": "Jitterbit API - Order Management",
    "version": "1.0.0",
    "description": "API desenvolvida para o teste teórico da Jitterbit. Gerencia a criação, leitura, atualização e exclusão de pedidos."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/order": {
      "post": {
        "summary": "Cria um novo pedido",
        "description": "Recebe o payload original e faz o mapping para salvar no banco de dados.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "numeroPedido": "v10089015vdb-01",
                "valor Total": 10000,
                "dataCriacao": "2023-07-19T12:24:11.5299601+00:00",
                "items": [
                  {
                    "idItem": "2434",
                    "quantidadeltem": 1,
                    "valorltem": 1000
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Pedido criado com sucesso" },
          "500": { "description": "Erro interno ao criar pedido" }
        }
      }
    },
    "/order/list": {
      "get": {
        "summary": "Lista todos os pedidos",
        "responses": {
          "200": { "description": "Lista de pedidos retornada com sucesso" }
        }
      }
    },
    "/order/{id}": {
      "get": {
        "summary": "Busca um pedido pelo ID",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "O orderId do pedido (ex: v10089015vdb-01)"
          }
        ],
        "responses": {
          "200": { "description": "Pedido encontrado" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um pedido existente",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "value": 15000
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Pedido atualizado" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "delete": {
        "summary": "Deleta um pedido pelo ID",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Pedido deletado com sucesso" },
          "404": { "description": "Pedido não encontrado" }
        }
      }
    }
  }
}
