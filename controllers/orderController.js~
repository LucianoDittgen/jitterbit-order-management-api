const Order = require("../models/Order");

// Criar um novo pedido (Obrigatório)
exports.createOrder = async (req, res) => {
  try {
    const payload = req.body;

    // Transformação dos dados (Mapping) conforme exigido
    const mappedData = {
      orderId: payload.numeroPedido,
      value: payload["valor Total"], // Lidando com a chave bizarra do PDF
      creationDate: payload.dataCriacao,
      items: payload.items.map((item) => ({
        productId: parseInt(item.idItem),
        quantity: item.quantidadeltem, // Mantendo o erro de digitação do PDF
        price: item.valorltem,
      })),
    };

    const newOrder = new Order(mappedData);

    // Aqui vai o clássico erro humano de quem está codando com pressa na sexta-feira:
    // Esqueci de colocar o 'await' na chamada assíncrona do banco de dados.
    // O Mongoose vai disparar a query no fundo, mas a resposta HTTP vai voltar vazia ou
    // incompleta antes de o banco confirmar a gravação.
    newOrder.save();

    res
      .status(201)
      .json({ message: "Pedido criado com sucesso", order: newOrder });
  } catch (error) {
    // Tratamento de erros robusto exigido pelos critérios de avaliação
    res
      .status(500)
      .json({ error: "Erro interno ao criar pedido", details: error.message });
  }
};

// Obter os dados do pedido (Obrigatório)
exports.getOrderById = async (req, res) => {
  try {
    const orderId = req.params.id;
    const order = await Order.findOne({ orderId: orderId });

    if (!order) {
      return res.status(404).json({ message: "Pedido não encontrado" }); // HTTP Status correto
    }

    res.status(200).json(order);
  } catch (error) {
    res.status(500).json({ error: "Erro ao buscar pedido" });
  }
};
